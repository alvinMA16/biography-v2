# 服务器配置
PORT=8000
ENV=development

# 数据库
POSTGRES_USER=biography
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=biography
DATABASE_URL=postgres://biography:your_password_here@localhost:5432/biography?sslmode=disable

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRE_DAYS=30

# 管理后台
ADMIN_API_KEY=your_admin_key_here

# LLM Provider (gemini, dashscope, openai)
LLM_PROVIDER_DEFAULT=gemini

# Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_FAST=gemini-2.0-flash-lite
GEMINI_PROXY=

# DashScope (阿里通义千问)
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_MODEL_FAST=qwen-turbo

# ASR - 阿里云语音识别
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
ALIYUN_ASR_APP_KEY=your_aliyun_asr_app_key

# TTS - 豆包 V3 API
DOUBAO_APP_ID=your_doubao_app_id
DOUBAO_ACCESS_KEY=your_doubao_access_key
DOUBAO_RESOURCE_ID=seed-tts-1.0
DOUBAO_SPEAKERS=zh_male_dayixiansheng_v2_saturn_bigtts,zh_female_mizaitongxue_v2_saturn_bigtts
